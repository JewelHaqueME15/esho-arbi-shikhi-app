# Copy to .env.local for local dev (vercel env pull .env.local also works
# once the project is linked and the Postgres storage is created).

# Auto-populated by Vercel when you create the Postgres storage integration
# (Storage tab -> Create Database -> Postgres). Do not set manually there;
# only needed here for local/non-Vercel testing.
POSTGRES_URL=postgres://user:password@host/dbname?sslmode=require

# Long random string used to sign session cookies (JWTs). Generate one with
# e.g. `openssl rand -base64 48` and set it in Vercel Project Settings ->
# Environment Variables.
JWT_SECRET=replace-with-a-long-random-string

# Code required to check "I am an admin/teacher" at signup. Never shipped
# to the browser - checked only inside /api/auth/signup.js and /api/migrate.js.
ADMIN_SIGNUP_CODE=ARBI-USTAD-2026
